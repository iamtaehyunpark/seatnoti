{
  "manifest_version": 3,
  "name": "Badger Course Watch",
  "version": "1.4.3",
  "description": "Monitors UW-Madison course enrollment for open seats.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://enroll.wisc.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Badger Course Watch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://enroll.wisc.edu/*"
      ],
      "js": [
        "exporter.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dictionaries.js"
      ],
      "matches": [
        "https://enroll.wisc.edu/*"
      ]
    }
  ]
}