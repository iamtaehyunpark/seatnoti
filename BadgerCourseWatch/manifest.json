{
  "manifest_version": 3,
  "name": "Badger Course Watch",
  "version": "1.4.0",
  "description": "Monitors UW-Madison course enrollment for open seats.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://enroll.wisc.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Badger Course Watch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}